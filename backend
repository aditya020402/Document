    def _basic_text_cleaning(self, text: str) -> str:
        """UPDATED: Perform basic regex-based text cleaning while preserving image analysis"""
        
        # Remove page markers but preserve image analysis blocks
        text = re.sub(r'--- PAGE \d+ ---', '', text)
        text = re.sub(r'--- END PAGE \d+ ---', '', text)
        
        # CHANGED: Don't remove image analysis markers - keep them for automation analysis
        # Preserve [IMAGE_X_ANALYSIS] blocks
        
        # Remove common OCR noise patterns but be more careful around image blocks
        ocr_noise_patterns = [
            r'\b[A-Z]{1}\s+[A-Z]{1}\s+[A-Z]{1}\b',  # Scattered single letters
            r'\b\d{1}\s+\d{1}\s+\d{1}\b',  # Scattered single digits
            r'[|¦!]{3,}',  # Multiple vertical bars/pipes (changed from 2+ to 3+)
            r'_{4,}',  # Multiple underscores (changed from 3+ to 4+)
            r'-{6,}',  # Multiple dashes (changed from 5+ to 6+)
            r'\s{4,}',  # Multiple spaces (changed from 3+ to 4+)
        ]
        
        for pattern in ocr_noise_patterns:
            text = re.sub(pattern, ' ', text)
        
        # Remove common header/footer patterns
        header_footer_patterns = [
            r'Page \d+ of \d+',
            r'Page \d+',
            r'©.*?\d{4}',
            r'Confidential.*?$',
            r'Document.*?Version.*?\d+',
        ]
        
        for pattern in header_footer_patterns:
            text = re.sub(pattern, '', text, flags=re.MULTILINE | re.IGNORECASE)
        
        # Clean up whitespace but preserve image analysis structure
        text = re.sub(r'\n\s*\n\s*\n', '\n\n', text)  # Multiple newlines to double
        text = re.sub(r' +', ' ', text)  # Multiple spaces to single
        text = text.strip()
        
        return text
    
    async def _ai_content_filtering(self, text: str) -> str:
        """Use AI to identify and filter relevant content"""
        
        if len(text) > 8000:
            text = text[:8000]
        
        filtering_prompt = f"""
        Clean this document text for automation analysis. Remove headers, footers, page numbers, and OCR noise.
        Keep: process descriptions, tasks, workflows, data definitions, business rules, image analysis blocks.
        Return only the cleaned text:

        {text}
        """
        
        response = await self.llm.ainvoke([HumanMessage(content=filtering_prompt)])
        return response.content.strip()
    
    def _remove_headers_footers(self, text: str) -> str:
        """Remove repeated headers and footers"""
        
        lines = text.split('\n')
        if len(lines) < 10:
            return text
        
        # Simple approach: remove very short lines that appear multiple times
        line_counts = {}
        for line in lines:
            clean_line = re.sub(r'\d+', 'NUM', line.strip())
            if 5 < len(clean_line) < 50:
                line_counts[clean_line] = line_counts.get(clean_line, 0) + 1
        
        # Remove lines that appear 3+ times
        repetitive_patterns = {line for line, count in line_counts.items() if count >= 3}
        
        filtered_lines = []
        for line in lines:
            clean_line = re.sub(r'\d+', 'NUM', line.strip())
            if clean_line not in repetitive_patterns:
                filtered_lines.append(line)
        
        return '\n'.join(filtered_lines)
    
    async def _extract_key_sections(self, text: str) -> Dict[str, Any]:
        """Extract and categorize key sections"""
        
        # Define automation keywords
        automation_keywords = {
            'process_words': ['process', 'workflow', 'procedure', 'steps', 'method'],
            'task_words': ['task', 'activity', 'operation', 'action', 'function'],
            'data_words': ['data', 'information', 'input', 'output', 'field', 'form'],
            'decision_words': ['if', 'when', 'condition', 'criteria', 'rule']
        }
        
        sentences = re.split(r'[.!?]+', text)
        sections = {
            'process_descriptions': [],
            'task_instructions': [],
            'data_definitions': [],
            'decision_rules': []
        }
        
        for sentence in sentences:
            sentence = sentence.strip()
            if len(sentence) < 10:  # Keep all meaningful sentences
                continue
            
            sentence_lower = sentence.lower()
            
            # Categorize sentences (keep full sentences, no truncation)
            if any(word in sentence_lower for word in automation_keywords['process_words']):
                sections['process_descriptions'].append(sentence)
                
            if any(word in sentence_lower for word in automation_keywords['task_words']):
                sections['task_instructions'].append(sentence)
                
            if any(word in sentence_lower for word in automation_keywords['data_words']):
                sections['data_definitions'].append(sentence)
                
            if any(word in sentence_lower for word in automation_keywords['decision_words']):
                sections['decision_rules'].append(sentence)
        
        # AI-powered key phrases extraction
        ai_key_phrases = await self._extract_ai_key_phrases(text)
        
        return {
            'sections': sections,
            'key_phrases': ai_key_phrases,
            'relevant_sentences': [s for s in sentences if len(s.strip()) > 10]
        }

    async def _extract_ai_key_phrases(self, text: str) -> List[str]:
        """Extract automation-related key phrases using AI"""
        
        analysis_text = text[:4000] if len(text) > 4000 else text
        
        key_phrases_prompt = f"""
        Analyze this document text and extract 10-15 key phrases that are most relevant for automation.
        Focus on: technical terms, process names, tools, commands, systems, workflows, and automation concepts.
        
        Return only the key phrases as a simple comma-separated list (no explanations):
        
        Document text:
        {analysis_text}
        """
        
        response = await self.llm.ainvoke([HumanMessage(content=key_phrases_prompt)])
        ai_response = response.content.strip()
        
        # Parse comma-separated phrases
        phrases = [phrase.strip() for phrase in ai_response.split(',')]
        clean_phrases = []
        for phrase in phrases:
            clean_phrase = phrase.strip('"\'').strip()
            if len(clean_phrase) > 2 and len(clean_phrase) < 50:
                clean_phrases.append(clean_phrase)
        
        return clean_phrases[:15]
    
