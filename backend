            }}
        }}

        DOCUMENT ANALYSIS CONTEXT:
        - Overall Automation Score: {analysis.get('overall_automation_score', 6)}/10
        - Automation Feasibility: {analysis.get('automation_feasibility_score', 5)}/10
        
        IMPROVED DOCUMENT CONTENT:
        {content[:4000]}
        """
        
        response = await self.llm.ainvoke([HumanMessage(content=commands_prompt)])
        return json.loads(response.content)
    
    # NEW AGENT 5: Script Generation Agent (replaces DAG generation)
    async def _script_generation_agent(self, state: WorkflowState) -> WorkflowState:
        """NEW AGENT 5: Generate Python automation script based on commands analysis"""
        
        print("📜 Script Generation Agent: Creating Python automation script...")
        
        automation_commands = state['automation_commands']
        analysis = state['automation_analysis']
        
        # Determine if script generation is viable
        automation_percentage = automation_commands.get('automation_summary', {}).get('automation_percentage', 0)
        
        if automation_percentage < 30:  # Low automation threshold
            # Generate explanation for why script cannot be created
            script_data = await self._generate_low_automation_explanation(automation_commands, automation_percentage)
        else:
            # Generate actual Python script
            script_data = await self._generate_python_automation_script(automation_commands, analysis)
        
        state['generated_script'] = script_data
        state['current_step'] = 'complete'
        
        return state
    
    async def _generate_low_automation_explanation(self, automation_commands: Dict, percentage: int) -> Dict[str, Any]:
        """Generate explanation when automation threshold is too low"""
        
        ui_tasks = automation_commands.get('ui_only_tasks', [])
        
        explanation = f"""
# Automation Script Generation - Insufficient Automation Level

## Analysis Results
- **Automation Percentage**: {percentage}%
- **Threshold Required**: 30% minimum
- **Status**: Script generation not recommended

## Reasons for Low Automation Score:

"""
        
        for i, ui_task in enumerate(ui_tasks, 1):
            explanation += f"{i}. **{ui_task.get('step_description', 'UI Task')}**\n"
            explanation += f"   - Reason: {ui_task.get('reason', 'Manual interaction required')}\n"
            explanation += f"   - Alternative: {ui_task.get('alternative_suggestion', 'No automated alternative available')}\n\n"
        
        explanation += """
## Recommendations:
1. Review document for more specific technical steps
2. Replace UI interactions with API calls or CLI commands where possible
3. Add more detailed technical procedures
4. Consider breaking down complex manual steps into smaller automatable tasks

## Next Steps:
- Improve document with more technical details
- Add specific commands and API endpoints
- Reduce dependency on manual UI interactions
"""
        
        return {
            'script_type': 'Analysis Report',
            'automation_viable': False,
            'automation_percentage': percentage,
            'explanation': explanation,
            'recommendations': [
                'Add more technical implementation details',
                'Replace UI steps with command-line alternatives',
                'Include API endpoints and technical specifications',
                'Break down complex manual processes'
            ],
            'threshold_met': False,
            'code': None,
            'requirements': None,
            'execution_steps': None
        }
    
    async def _generate_python_automation_script(self, automation_commands: Dict, analysis: Dict) -> Dict[str, Any]:
        """Generate actual Python automation script"""
        
        script_prompt = f"""
        Generate a complete Python automation script based on the automation commands analysis.
        
        Return JSON with this structure:
        {{
            "code": "<complete python script>",
            "requirements": ["<package1>", "<package2>"],
            "execution_steps": ["<step1>", "<step2>"],
            "parameters_required": ["<param1>", "<param2>"],
            "script_description": "<description of what the script does>",
            "automation_coverage": "<percentage of tasks automated>",
            "manual_steps_remaining": ["<step1>", "<step2>"],
            "notes": "<important usage notes>"
        }}
        
        Create a robust Python script that:
        1. Handles the automatable steps identified
        2. Uses appropriate Python libraries (requests, subprocess, os, etc.)
        3. Includes proper error handling
        4. Has clear logging and output
        5. Supports both Linux and Windows where possible
        6. Includes parameter validation
        7. Has clear documentation

        AUTOMATION COMMANDS ANALYSIS:
        {json.dumps(automation_commands, indent=2)}
        
        OVERALL AUTOMATION SCORE: {analysis.get('overall_automation_score', 6)}/10
        """
        
        response = await self.llm.ainvoke([HumanMessage(content=script_prompt)])
        script_result = json.loads(response.content)
        
        # Add metadata
        script_result.update({
            'script_type': 'Python Automation Script',
            'automation_viable': True,
            'automation_percentage': automation_commands.get('automation_summary', {}).get('automation_percentage', 70),
            'threshold_met': True,
            'explanation': None
        })
        
        return script_result
    
    # NEW METHOD: Process text documents (non-PDF)
    async def process_text_document(self, text_file_path: str) -> Dict[str, Any]:
        """Process text document (non-PDF) through workflow"""
        
        # Read the text file
        with open(text_file_path, 'r', encoding='utf-8') as f:
            text_content = f.read()
        
        # Create initial state with text content instead of PDF parsing
        initial_state = WorkflowState(
            pdf_path=text_file_path,
            parsed_content={
                'combined_text': text_content,
                'page_breakdown': [],
                'total_pages': 1,
                'processing_summary': {
                    'total_text_length': len(text_content),
                    'pages_with_images': 0,
                    'total_images': 0,
                    'pages_with_multimodal_content': 0,
                    'image_analysis_count': 0,
                    'input_type': 'text'
                },
                'image_analysis': []
            },
            cleaned_content={},
            automation_analysis={},
            improved_document={},
            automation_commands={},
            generated_script={},
            messages=[],
            current_step="text_parsing_complete"
        )
        
        # Skip PDF parsing agent and go directly to cleaning
        print("📝 Processing text input directly...")
        
        # Run cleaning agent
        initial_state = await self._text_cleaning_agent(initial_state)
        
        # Run analysis agent
        initial_state = await self._enhanced_automation_analysis_agent(initial_state)
        
        # Run automation commands agent
        initial_state = await self._automation_commands_agent(initial_state)
        
        # Run script generation agent
        final_state = await self._script_generation_agent(initial_state)
        
        return {
            'parsed_content': final_state['parsed_content'],
            'cleaned_content': final_state['cleaned_content'],
            'automation_analysis': final_state['automation_analysis'],
            'improved_document': final_state['improved_document'],
            'automation_commands': final_state.get('automation_commands', {}),
            'generated_script': final_state['generated_script']
        }
    
