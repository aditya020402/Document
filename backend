    def _extract_rule_data(self, text: str) -> Dict[str, Any]:
        """Extract structural data for rule-based analysis"""
        
        # Count commands and analyze structure
        command_patterns = [
            r'\b(run|execute|start|stop|restart|check|verify|validate|install|configure|deploy|backup|restore|copy|move|delete|create|update|modify|monitor)\b',
            r'\b(curl|wget|ssh|scp|grep|awk|sed|find|ps|kill|systemctl|docker|kubectl|git|pip|npm|yarn)\b',
            r'\$\s*\w+',
            r'``````',
            r'`[^`]+`'
        ]
        
        commands = []
        for pattern in command_patterns:
            matches = re.findall(pattern, text, re.IGNORECASE)
            commands.extend(matches)
        
        # Detect quality flags
        vague_terms = re.findall(r'\b(check|verify|ensure|make sure|confirm|validate)\s+(?!with|using|by|via)\w*', text, re.IGNORECASE)
        manual_decisions = re.findall(r'\b(manually|human|approval|review|decide|judgment|discretion|if\s+needed)\b', text, re.IGNORECASE)
        ui_interactions = re.findall(r'\b(click|button|interface|GUI|dashboard|browser|web\s+page)\b', text, re.IGNORECASE)
        
        # Analyze logic and decision points
        decision_points = re.findall(r'\b(if|when|unless|depending|based\s+on|in\s+case|should)\b', text, re.IGNORECASE)
        conditional_statements = re.findall(r'\bif\s+.*?then\b', text, re.IGNORECASE)
        
        return {
            'commands': {
                'total_commands': len(commands),
                'unique_commands': len(set(commands)),
                'command_types': list(set(commands))
            },
            'quality_flags': {
                'vague_terms': len(vague_terms),
                'manual_decisions': len(manual_decisions),
                'ui_interactions': len(ui_interactions),
                'vague_terms_list': vague_terms,
                'manual_decisions_list': manual_decisions
            },
            'logic_structure': {
                'decision_points': len(decision_points),
                'conditional_statements': len(conditional_statements),
                'decision_list': decision_points
            }
        }
    
    async def _perform_five_metric_analysis(self, text: str, rule_data: Dict) -> Dict[str, Any]:
        """Perform comprehensive 5-metric runbook analysis"""
        
        analysis_prompt = f"""
        You are an expert runbook automation analyst. Score this runbook on 5 metrics (0-10 scale) for automation feasibility.

        RULE DATA ANALYSIS:
        - Total Commands Found: {rule_data['commands']['total_commands']}
        - Vague Terms Found: {rule_data['quality_flags']['vague_terms']}
        - Manual Decision Points: {rule_data['quality_flags']['manual_decisions']}
        - UI Interactions: {rule_data['quality_flags']['ui_interactions']}
        - Decision Points: {rule_data['logic_structure']['decision_points']}

        Return your analysis as a JSON object with this exact structure:
