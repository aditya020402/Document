class DocumentAutomationWorkflow:
    def __init__(self):
        # Initialize LLM with GPT-4o mini for multimodal capabilities
        self.llm = ChatOpenAI(
            model="gpt-4o-mini",
            temperature=0.1,
            azure_endpoint="your-azure-endpoint",
            api_key="your-api-key",
            api_version="2024-07-18"
        )
        
        # Build the workflow graph
        self.workflow = self._build_workflow()
    
    def _build_workflow(self) -> StateGraph:
        """Build the LangGraph workflow"""
        
        # Create state graph
        workflow = StateGraph(WorkflowState)
        
        # Add nodes for the 5-step process
        workflow.add_node("parse_document", self._parse_document_agent)
        workflow.add_node("clean_text", self._text_cleaning_agent)
        workflow.add_node("analyze_automation", self._enhanced_automation_analysis_agent)
        workflow.add_node("automation_commands", self._automation_commands_agent)
        workflow.add_node("generate_script", self._script_generation_agent)
        
        # Add edges
        workflow.add_edge(START, "parse_document")
        workflow.add_edge("parse_document", "clean_text")
        workflow.add_edge("clean_text", "analyze_automation")
        workflow.add_edge("analyze_automation", "automation_commands")
        workflow.add_edge("automation_commands", "generate_script")
        workflow.add_edge("generate_script", END)
        
        return workflow.compile()
    
    # AGENT 1: Parse PDF using multimodal GPT
    async def _parse_document_agent(self, state: WorkflowState) -> WorkflowState:
        """Agent 1: Parse PDF and extract text + multimodal image analysis"""
        
        print("🔍 Document Parser Agent: Processing PDF with multimodal GPT-4o mini...")
        
        # Process each page sequentially to maintain order
        combined_content = await self._extract_content_by_page(state['pdf_path'])
        
        # Update state with properly ordered content
        state['parsed_content'] = {
            'combined_text': combined_content['full_text'],
            'page_breakdown': combined_content['pages'],
            'total_pages': combined_content['total_pages'],
            'processing_summary': combined_content['summary'],
            'image_analysis': combined_content.get('image_analysis', [])
        }
        state['current_step'] = 'parsing_complete'
        
        return state
    
    async def _extract_content_by_page(self, pdf_path: str) -> Dict[str, Any]:
        """Extract text and images page by page using multimodal GPT-4o mini - FIXED"""
        
        combined_text = ""
        page_details = []
        image_analysis = []
        
        # Open PDF with PyMuPDF for comprehensive processing
        doc = fitz.open(pdf_path)
        total_pages = len(doc)
        
        print(f"Processing {total_pages} pages with multimodal GPT-4o mini...")
        
        for page_num in range(total_pages):
            print(f"Processing page {page_num + 1}/{total_pages}...")
            
            page = doc.load_page(page_num)
            
            # Step 1: Extract text content using PyMuPDF with proper sorting
            text_dict = page.get_text("dict", sort=True)
            page_text_content = self._extract_text_from_page_dict(text_dict)
            
            # Step 2: FIXED - Use multimodal GPT for images and embed descriptions
            image_list = page.get_images()
            page_multimodal_content = ""
            page_image_analysis = []
            
            if image_list:
                print(f"Found {len(image_list)} images on page {page_num + 1}, processing with multimodal GPT...")
                for img_index, img in enumerate(image_list):
                    try:
                        # Extract image
                        xref = img[0]
                        pix = fitz.Pixmap(doc, xref)
                        
                        if pix.n - pix.alpha < 4:  # GRAY or RGB
                            img_data = pix.tobytes("png")
                            
                            # FIXED: Use multimodal GPT and properly handle results
                            multimodal_result = await self._perform_multimodal_analysis(img_data, page_num + 1, img_index + 1)
                            
                            # FIXED: Always add image analysis to content, even if no text extracted
                            image_content_block = f"\n[IMAGE_{img_index + 1}_ANALYSIS]:\n"
                            image_content_block += f"Description: {multimodal_result['description']}\n"
                            image_content_block += f"Purpose: {multimodal_result['purpose']}\n"
                            image_content_block += f"Automation Relevance: {multimodal_result['automation_relevance']}\n"
                            
                            # Add extracted text if available
                            if multimodal_result['extracted_text'].strip():
                                image_content_block += f"Extracted Text: {multimodal_result['extracted_text']}\n"
                            else:
                                image_content_block += "Extracted Text: No text detected in image\n"
                            
                            image_content_block += f"[END_IMAGE_{img_index + 1}_ANALYSIS]\n"
                            
                            # Add to page content
                            page_multimodal_content += image_content_block
                            
                            # Add image analysis for frontend display
                            page_image_analysis.append({
                                'page': page_num + 1,
                                'image_index': img_index + 1,
                                'extracted_text': multimodal_result['extracted_text'],
                                'image_description': multimodal_result['description'],
                                'purpose': multimodal_result['purpose'],
                                'automation_relevance': multimodal_result['automation_relevance']
                            })
                        
                        pix = None
                        
                    except Exception as e:
                        print(f"Error processing image {img_index + 1} on page {page_num + 1}: {e}")
                        # Add error information to content
                        error_block = f"\n[IMAGE_{img_index + 1}_ERROR]: Failed to process image - {str(e)}\n"
                        page_multimodal_content += error_block
            
            # Step 3: FIXED - Combine text and multimodal content with proper integration
            page_combined = f"\n--- PAGE {page_num + 1} ---\n"
            page_combined += page_text_content
            
            # FIXED: Always add image analysis section if there are images
            if image_list:
                page_combined += f"\n--- IMAGES ANALYSIS FOR PAGE {page_num + 1} ---\n"
                page_combined += page_multimodal_content
                page_combined += f"--- END IMAGES ANALYSIS FOR PAGE {page_num + 1} ---\n"
            
            page_combined += f"\n--- END PAGE {page_num + 1} ---\n\n"
            
            # Add to combined text
            combined_text += page_combined
            
            # FIXED: Store page details with correct multimodal content length
            page_details.append({
                'page_number': page_num + 1,
                'text_length': len(page_text_content),
                'image_count': len(image_list),
                'multimodal_content_length': len(page_multimodal_content),  # FIXED: Now correctly calculated
                'combined_length': len(page_combined)
            })
            
            # Add image analysis to results
            image_analysis.extend(page_image_analysis)
        
        doc.close()
        
        processing_summary = {
            'total_text_length': len(combined_text),
            'pages_with_images': sum(1 for p in page_details if p['image_count'] > 0),
            'total_images': sum(p['image_count'] for p in page_details),
            'pages_with_multimodal_content': sum(1 for p in page_details if p['multimodal_content_length'] > 0),
            'image_analysis_count': len(image_analysis)
        }
        
        return {
            'full_text': combined_text,
            'pages': page_details,
            'total_pages': total_pages,
            'summary': processing_summary,
            'image_analysis': image_analysis
        }
    
    def _extract_text_from_page_dict(self, text_dict: Dict) -> str:
        """Extract text from PyMuPDF text dictionary in proper order"""
        
        text_content = ""
        
        # Process blocks in order (already sorted by get_text with sort=True)
        for block in text_dict.get("blocks", []):
            if "lines" in block:  # Text block
                for line in block["lines"]:
                    line_text = ""
                    for span in line.get("spans", []):
                        line_text += span.get("text", "")
                    if line_text.strip():
                        text_content += line_text + "\n"
        
        return text_content
    
    async def _perform_multimodal_analysis(self, image_data: bytes, page_num: int, img_num: int) -> Dict[str, str]:
        """FIXED: Perform multimodal analysis using GPT-4o mini with better error handling"""
        
        try:
            # Convert image to base64
            img_base64 = base64.b64encode(image_data).decode('utf-8')
            
            # ENHANCED: Create more detailed multimodal prompt
            multimodal_prompt = f"""
            Analyze this image from page {page_num}, image {img_num} of a technical/business document and provide detailed information:

            1. **Extract ALL visible text** - Transcribe every piece of text you can see, including:
               - Labels, titles, headings
               - Body text, descriptions
               - Code snippets, commands
               - Menu items, button text
               - Technical terms, parameters
               - Numbers, dates, values
            
            2. **Describe what the image shows** - Be specific about:
               - Type of content (screenshot, diagram, chart, flowchart, etc.)
               - Visual elements and layout
               - Technical components shown
               - User interface elements if applicable
            
            3. **Explain the purpose** - Why this image is included:
               - What process or concept it illustrates
               - How it supports the document's content
               - What information it conveys
            
            4. **Automation relevance** - How it relates to automation:
               - Automatable processes shown
               - Technical workflows depicted
               - System interactions visible
               - Commands or APIs that could be automated

            Be thorough and detailed. If you see any text, extract ALL of it completely.

            Format your response EXACTLY as:
            EXTRACTED_TEXT: [transcribe ALL visible text here, be comprehensive]
            IMAGE_DESCRIPTION: [detailed description of what the image shows]
            PURPOSE: [why this image is in the document and what it illustrates]
            AUTOMATION_RELEVANCE: [detailed analysis of automation potential]
            """
            
            # Prepare message content
            message_content = [
                {
                    "type": "text",
                    "text": multimodal_prompt
                },
                {
                    "type": "image_url",
                    "image_url": {
                        "url": f"data:image/png;base64,{img_base64}",
                        "detail": "high"  # High detail for better text extraction
                    }
                }
            ]
            
            # Call GPT-4o mini
            print(f"🔍 Analyzing image {img_num} on page {page_num} with GPT-4o mini...")
            response = await self.llm.ainvoke([HumanMessage(content=message_content)])
            
            if not response or not response.content:
                print(f"⚠️ Empty response from GPT-4o mini for image {img_num}")
                return {
                    'extracted_text': '',
                    'description': 'Empty response from multimodal analysis',
                    'purpose': 'Analysis failed',
                    'automation_relevance': 'Could not analyze'
                }
            
            # FIXED: Better parsing of the response
            content = response.content.strip()
            print(f"✅ GPT-4o mini response length: {len(content)} characters")
            
            # Extract each section with improved parsing
            extracted_text = ""
            description = ""
            purpose = ""
            automation_relevance = ""
            
            # Parse line by line for better extraction
            lines = content.split('\n')
            current_section = None
            
            for line in lines:
                line = line.strip()
                if line.startswith('EXTRACTED_TEXT:'):
                    current_section = 'text'
                    extracted_text = line.replace('EXTRACTED_TEXT:', '').strip()
                elif line.startswith('IMAGE_DESCRIPTION:'):
                    current_section = 'description'
                    description = line.replace('IMAGE_DESCRIPTION:', '').strip()
                elif line.startswith('PURPOSE:'):
                    current_section = 'purpose'
                    purpose = line.replace('PURPOSE:', '').strip()
                elif line.startswith('AUTOMATION_RELEVANCE:'):
                    current_section = 'relevance'
                    automation_relevance = line.replace('AUTOMATION_RELEVANCE:', '').strip()
                elif line and current_section:
                    # Continue building the current section
                    if current_section == 'text':
                        extracted_text += ' ' + line
                    elif current_section == 'description':
                        description += ' ' + line
                    elif current_section == 'purpose':
                        purpose += ' ' + line
                    elif current_section == 'relevance':
                        automation_relevance += ' ' + line
            
            # Clean up the extracted content
            extracted_text = extracted_text.strip()
            description = description.strip() if description.strip() else 'Visual content detected but description not provided'
            purpose = purpose.strip() if purpose.strip() else 'Purpose analysis not available'
            automation_relevance = automation_relevance.strip() if automation_relevance.strip() else 'Automation analysis not available'
            
            print(f"📊 Image {img_num} analysis - Text extracted: {len(extracted_text)} chars")
            
            return {
                'extracted_text': extracted_text,
                'description': description,
                'purpose': purpose,
                'automation_relevance': automation_relevance
            }
            
        except Exception as e:
            print(f"❌ Multimodal GPT analysis error for image {img_num}: {e}")
            return {
                'extracted_text': '',
                'description': f'Error in multimodal analysis: {str(e)}',
                'purpose': 'Analysis failed due to error',
                'automation_relevance': f'Error occurred: {str(e)}'
            }
    
