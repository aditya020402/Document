                st.markdown("#### 📌 Important Notes")
                st.info(script_data['notes'])
            
            st.markdown("### 📦 Download Files")
            
            col1, col2, col3 = st.columns(3)
            
            with col1:
                if script_data.get('code'):
                    st.download_button(
                        label="🐍 Download Python Script",
                        data=script_data['code'],
                        file_name="automation_script.py",
                        mime="text/x-python",
                        help="Download the complete Python automation script"
                    )
            
            with col2:
                if script_data.get('requirements'):
                    requirements_content = "\n".join(script_data['requirements'])
                    st.download_button(
                        label="📋 Download Requirements.txt", 
                        data=requirements_content,
                        file_name="requirements.txt",
                        mime="text/plain",
                        help="Python packages required for the script"
                    )
            
            with col3:
                if script_data.get('execution_steps'):
                    instructions_content = "# Script Execution Instructions\n\n"
                    for i, step in enumerate(script_data['execution_steps'], 1):
                        instructions_content += f"{i}. {step}\n"
                    
                    if script_data.get('parameters_required'):
                        instructions_content += "\n## Required Parameters:\n"
                        for param in script_data['parameters_required']:
                            instructions_content += f"- {param}\n"
                    
                    st.download_button(
                        label="📖 Download Instructions",
                        data=instructions_content,
                        file_name="execution_instructions.md",
                        mime="text/markdown",
                        help="Step-by-step instructions to run the script"
                    )
            
            if script_data.get('requirements'):
                st.markdown("#### 📦 Required Python Packages")
                deps_display = []
                for dep in script_data['requirements']:
                    deps_display.append(f"`{dep}`")
                st.markdown(" • ".join(deps_display))

# Cleanup
if tmp_file_path and Path(tmp_file_path).exists():
    Path(tmp_file_path).unlink(missing_ok=True)
